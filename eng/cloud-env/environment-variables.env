# Spring Voyage — Claude Code cloud environment variables.
#
# Paste into the "Environment variables" field of the New cloud environment form.
# Non-secret .NET CLI toggles only. NEVER add credentials here — this field is
# visible to anyone using the environment.
#
# PATH and DOTNET_ROOT are wired by eng/cloud-env/setup.sh, not here, because the
# .env field does not expand $HOME.

# .NET CLI — quiet, non-interactive, no telemetry
DOTNET_NOLOGO=1
DOTNET_CLI_TELEMETRY_OPTOUT=1
DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
DOTNET_GENERATE_ASPNET_CERTIFICATE=false
NUGET_XMLDOC_MODE=skip

# Optional: also run the warm `dotnet build` in setup.sh (off by default; see
# eng/cloud-env/README.md). Leave unset unless you've confirmed setup still
# caches under the ~5-min window.
# CLOUD_ENV_WARM_BUILD=1
