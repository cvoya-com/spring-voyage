#!/usr/bin/env bash
# voyage — operator-facing wrapper installed by eng/install/install.sh
# as ~/.local/bin/voyage. Dispatches install / uninstall / status /
# logs / restart / version to the bundle scripts and `deploy.sh` so operators
# never need to remember where the install root or spring.env live.
#
# Configuration is read from the environment so the script is identical
# across installs:
#
#   SPRING_VOYAGE_HOME   Install root. Default: ~/.spring-voyage
#   SPRING_ENV_FILE      spring.env path. Default: ${SPRING_VOYAGE_HOME}/spring.env
#
# Subcommands:
#   status              Show install version, container + dispatcher health,
#                       web URL, and log paths. Pretty-printed.
#   logs [service]      Tail container logs (no arg = all containers).
#                       `logs dispatcher` tails the host-process dispatcher log.
#   restart             Restart the stack (delegates to deploy.sh restart).
#   install             (Re)install Spring Voyage from a release.
#   uninstall           Uninstall (preserves operator data; --purge for factory reset).
#   version             Print the installed version + platform image tag.
#   gh-webhook-forward  Forward GitHub webhooks from a repo to the local API
#                       (delegates to bundle/gh-webhook-forward.sh).
#   help                Show usage.
#
# Tests:  eng/install/tests/test-install.sh
# Design: docs/decisions/0042-local-operator-installer.md

set -euo pipefail

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
INSTALL_ROOT="${SPRING_VOYAGE_HOME:-${HOME}/.spring-voyage}"
BUNDLE="${INSTALL_ROOT}/current"
SPRING_ENV="${SPRING_ENV_FILE:-${INSTALL_ROOT}/spring.env}"
MANIFEST="${BUNDLE}/manifest.json"
DISPATCHER_PID_FILE="${INSTALL_ROOT}/host/spring-dispatcher.pid"
DISPATCHER_LOG_FILE="${INSTALL_ROOT}/host/spring-dispatcher.log"

# Canonical release entry-point — used by the `install` subcommand for
# re-installs. Kept in sync with eng/install/install.sh's REPO_OWNER /
# REPO_NAME constants.
RELEASE_INSTALL_URL="https://github.com/cvoya-com/spring-voyage/releases/latest/download/install.sh"

# ---------------------------------------------------------------------------
# Output helpers — match eng/install/install.sh / eng/deploy/setup.sh.
# ---------------------------------------------------------------------------
if [[ -t 1 ]]; then
  BOLD=$'\033[1m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  RED=$'\033[0;31m'; CYAN=$'\033[0;36m'; NC=$'\033[0m'
else
  BOLD=''; GREEN=''; YELLOW=''; RED=''; CYAN=''; NC=''
fi

header() { printf "\n${BOLD}${CYAN}==> %s${NC}\n" "$1"; }
ok()     { printf "  ${GREEN}OK${NC}    %s\n" "$*"; }
info()   { printf "        %s\n" "$*"; }
warn()   { printf "  ${YELLOW}WARN${NC}  %s\n" "$*"; }
bad()    { printf "  ${RED}FAIL${NC}  %s\n" "$*"; }

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
  cat <<'USAGE'
Usage: voyage <command> [args...]

Commands:
  status              Show install version, container/dispatcher health, log paths.
  logs [service]      Tail container or dispatcher logs.
                      `voyage logs dispatcher` tails the host-process log.
  restart             Restart the stack.
  install             (Re)install Spring Voyage from a release.
  uninstall           Uninstall (preserves operator data; use --purge for factory reset).
  version             Print the installed version.
  gh-webhook-forward  Forward GitHub webhooks from a repo to the local API.
                      Pass-through flags: --repo owner/repo [--url URL] [--env PATH]
                                          [--events list]
  help                Show this help.

Environment overrides:
  SPRING_VOYAGE_HOME   Install root (default: ~/.spring-voyage).
  SPRING_ENV_FILE      Path to spring.env (default: $SPRING_VOYAGE_HOME/spring.env).

For day-to-day platform CLI use, run `spring` instead.
USAGE
}

# ---------------------------------------------------------------------------
# Bundle helpers
# ---------------------------------------------------------------------------
require_bundle() {
  if [[ ! -e "${BUNDLE}" && ! -L "${BUNDLE}" ]]; then
    bad "No installed bundle at ${BUNDLE}."
    info "Run \`voyage install\` to (re)install."
    exit 1
  fi
}

# Reads a top-level scalar string from manifest.json without depending on jq.
# Usage: manifest_field <key> -> echoes the value, or empty string if missing.
manifest_field() {
  local key="$1"
  [[ -r "${MANIFEST}" ]] || return 0
  # Match `"key": "value"` allowing surrounding whitespace.
  awk -v k="\"${key}\"" '
    {
      # Find "key": "value"
      idx = index($0, k)
      if (idx == 0) next
      rest = substr($0, idx + length(k))
      sub(/^[[:space:]]*:[[:space:]]*"/, "", rest)
      sub(/".*$/, "", rest)
      print rest
      exit
    }
  ' "${MANIFEST}"
}

# Reads a `KEY=value` line from spring.env. Strips surrounding quotes.
spring_env_field() {
  local key="$1"
  [[ -r "${SPRING_ENV}" ]] || return 0
  awk -v k="${key}" -F'=' '
    $0 ~ "^"k"=" {
      sub("^"k"=", "", $0)
      gsub(/^"|"$|^'\''|'\''$/, "", $0)
      print
      exit
    }
  ' "${SPRING_ENV}"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------
cmd_version() {
  require_bundle
  local v image
  v="$(manifest_field version)"
  image="$(manifest_field platform_image)"
  printf 'voyage version %s\n' "${v:-unknown}"
  if [[ -n "${image}" ]]; then
    printf 'platform image:        %s\n' "${image}"
  fi
}

cmd_status() {
  require_bundle

  local v image deploy_scheme deploy_hostname caddy_http_port caddy_https_port authority web_url
  v="$(manifest_field version)"
  image="$(manifest_field platform_image)"

  header "Install"
  if [[ -n "${v}" ]]; then
    ok "version ${v}"
  else
    warn "version unknown (manifest.json missing or unreadable)"
  fi
  if [[ -n "${image}" ]]; then
    info "platform image: ${image}"
  fi
  info "install root:   ${INSTALL_ROOT}"
  info "bundle:         ${BUNDLE}"
  info "spring.env:     ${SPRING_ENV}"

  header "Containers"
  if [[ -x "${BUNDLE}/deploy.sh" ]]; then
    if SPRING_ENV_FILE="${SPRING_ENV}" "${BUNDLE}/deploy.sh" status; then
      :
    else
      warn "deploy.sh status returned non-zero"
    fi
  else
    bad "deploy.sh not found in ${BUNDLE}"
  fi

  header "Dispatcher"
  if [[ -f "${DISPATCHER_PID_FILE}" ]]; then
    local pid
    pid="$(tr -d '[:space:]' < "${DISPATCHER_PID_FILE}" 2>/dev/null || true)"
    if [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null; then
      ok "running (PID ${pid})"
    else
      warn "stopped (stale PID file at ${DISPATCHER_PID_FILE}, PID ${pid:-unknown} not alive)"
    fi
  else
    info "not running (no PID file at ${DISPATCHER_PID_FILE})"
  fi
  info "log: ${DISPATCHER_LOG_FILE}"

  header "Web URL"
  deploy_scheme="$(spring_env_field DEPLOY_SCHEME)"
  deploy_hostname="$(spring_env_field DEPLOY_HOSTNAME)"
  [[ -z "${deploy_hostname}" ]] && deploy_hostname="localhost"
  if [[ -z "${deploy_scheme}" ]]; then
    # Mirror install.sh: loopback hosts serve http, everything else https.
    case "${deploy_hostname}" in
      localhost | *.localhost | 127.0.0.1 | ::1) deploy_scheme="http" ;;
      *) deploy_scheme="https" ;;
    esac
  fi
  # Caddy publishes the API/portal on a host port the installer may have remapped
  # off 80/443 (rootless Podman can't bind privileged ports). Include it in the
  # URL so the printed address actually resolves — a bare "http://localhost"
  # silently means port 80, which a remapped install doesn't serve.
  if [[ "${deploy_scheme}" == "https" ]]; then
    caddy_https_port="$(spring_env_field CADDY_HTTPS_PORT)"
    [[ -z "${caddy_https_port}" ]] && caddy_https_port="443"
    if [[ "${caddy_https_port}" == "443" ]]; then
      authority="${deploy_hostname}"
    else
      authority="${deploy_hostname}:${caddy_https_port}"
    fi
  else
    caddy_http_port="$(spring_env_field CADDY_HTTP_PORT)"
    [[ -z "${caddy_http_port}" ]] && caddy_http_port="80"
    if [[ "${caddy_http_port}" == "80" ]]; then
      authority="${deploy_hostname}"
    else
      authority="${deploy_hostname}:${caddy_http_port}"
    fi
  fi
  web_url="${deploy_scheme}://${authority}"
  info "${web_url}"

  header "API endpoint"
  info "${web_url}   (spring CLI; override with SPRING_API_URL)"

  header "Logs"
  info "containers:  podman logs spring-api  (also: spring-web, spring-worker, …)"
  info "dispatcher:  voyage logs dispatcher   (file: ${DISPATCHER_LOG_FILE})"
  printf '\n'
}

cmd_logs() {
  local service="${1:-}"
  if [[ "${service}" == "dispatcher" ]]; then
    if [[ ! -f "${DISPATCHER_LOG_FILE}" ]]; then
      bad "Dispatcher log file not found at ${DISPATCHER_LOG_FILE}"
      info "If the dispatcher has never started, check \`voyage status\`."
      exit 1
    fi
    exec tail -F "${DISPATCHER_LOG_FILE}"
  fi
  require_bundle
  if [[ ! -x "${BUNDLE}/deploy.sh" ]]; then
    bad "deploy.sh not found in ${BUNDLE}."
    exit 1
  fi
  if [[ -n "${service}" ]]; then
    SPRING_ENV_FILE="${SPRING_ENV}" exec "${BUNDLE}/deploy.sh" logs "${service}"
  fi
  SPRING_ENV_FILE="${SPRING_ENV}" exec "${BUNDLE}/deploy.sh" logs
}

cmd_restart() {
  require_bundle
  if [[ ! -x "${BUNDLE}/deploy.sh" ]]; then
    bad "deploy.sh not found in ${BUNDLE}."
    exit 1
  fi
  SPRING_ENV_FILE="${SPRING_ENV}" exec "${BUNDLE}/deploy.sh" restart "$@"
}

cmd_install() {
  exec curl -fSL "${RELEASE_INSTALL_URL}" | bash "$@"
}

cmd_uninstall() {
  if [[ -L "${BUNDLE}" && ! -e "${BUNDLE}" ]]; then
    bad "Bundle symlink ${BUNDLE} is dangling — the releases directory may have been partially removed."
    info "Remove the broken symlink and re-install: rm -f ${BUNDLE} && voyage install"
    exit 1
  fi
  if [[ -x "${BUNDLE}/uninstall.sh" ]]; then
    SPRING_VOYAGE_HOME="${INSTALL_ROOT}" exec "${BUNDLE}/uninstall.sh" "$@"
  fi
  bad "uninstall.sh not found in ${BUNDLE}. Re-download via install.sh."
  exit 1
}

cmd_gh_webhook_forward() {
  require_bundle
  local script="${BUNDLE}/gh-webhook-forward.sh"
  if [[ ! -x "${script}" ]]; then
    bad "gh-webhook-forward.sh not found in ${BUNDLE}."
    info "This installation may pre-date the bundled forwarder. Run \`voyage install\` to refresh."
    exit 1
  fi
  # The bundled script reads GitHub__WebhookSecret from --env (defaults to
  # eng/config/spring.env in dev). Point it at this install's spring.env
  # unless the caller has overridden it via --env on the command line.
  local has_env_flag=0 arg
  for arg in "$@"; do
    if [[ "${arg}" == "--env" || "${arg}" == --env=* ]]; then
      has_env_flag=1
      break
    fi
  done
  if [[ "${has_env_flag}" -eq 0 ]]; then
    exec "${script}" --env "${SPRING_ENV}" "$@"
  fi
  exec "${script}" "$@"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "${1:-help}" in
  status)
    shift
    cmd_status "$@" ;;
  logs)
    shift
    cmd_logs "$@" ;;
  restart)
    shift
    cmd_restart "$@" ;;
  install)
    shift
    cmd_install "$@" ;;
  uninstall)
    shift
    cmd_uninstall "$@" ;;
  gh-webhook-forward)
    shift
    cmd_gh_webhook_forward "$@" ;;
  version|--version|-V)
    shift || true
    cmd_version ;;
  -h|--help|help)
    usage ;;
  *)
    usage
    exit 0 ;;
esac
