# syntax=docker/dockerfile:1.7
#
# Spring Voyage — magazine LangGraph orchestrator image (ADR-0066).
#
# BYOI conformance path 3 (docs/architecture/agent-runtime.md § 7): the
# container speaks A2A 0.3.x natively via the Spring Voyage Agent SDK — no
# agent-base bridge. The entrypoint runs the magazine orchestrator, an
# always-on LangGraph engine that drives the editorial pipeline by delegating
# to the team's specialist agents over sv.messaging and resuming on their
# replies. It is the default image for the generic `a2a-process` runtime
# (eng/runtime-catalog/runtime-catalog.yaml); other engines ship their own
# image and reuse the same runtime.
#
# Build (preferred): eng/build/build-agent-images.sh
# Build (standalone):
#   docker build -f eng/build/Dockerfile.agent.langgraph \
#     -t localhost/spring-voyage-langgraph-orchestrator:latest .

# Pinned to the same interpreter line as eng/build/Dockerfile.agent-base and
# Dockerfile.agent.dapr — every Python-bearing platform image tracks 3.13.
FROM docker.io/library/python:3.13.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    AGENT_PORT=8999

# tini for clean SIGTERM forwarding (uniform with the other agent images);
# ca-certificates so httpx can verify TLS endpoints (the platform MCP) and so
# the co-hosted Claude CLI can reach Anthropic; curl because the platform's
# container readiness probe execs `curl .../.well-known/agent.json` *inside*
# this container (IContainerRuntime.ProbeContainerHttpAsync) — so every
# platform-built agent image MUST carry curl on PATH, matching
# Dockerfile.agent-base. Without it the probe fails for the full readiness
# window and the dispatcher tears the (otherwise healthy) container down.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        tini \
 && rm -rf /var/lib/apt/lists/*

# The orchestrator delegates natural-language steps — interpreting a free-form
# director brief (ADR-0066) — to Claude via the SDK's `complete()`, which shells
# the Claude Code CLI. Install Node + the CLI (pinned to the same version as the
# claude-code agent image) so `claude` is on PATH; the a2a-process launcher
# injects CLAUDE_CODE_OAUTH_TOKEN at dispatch time, and the engine itself never
# launches an LLM. The `claude --version` probe fails the build loudly on a
# regression. A purely deterministic engine that never calls `complete()`
# simply leaves the CLI unused.
ARG NODE_VERSION=22
ARG CLAUDE_CODE_VERSION=2.1.98
# curl is already installed (permanent, above). gnupg is only needed to verify
# the NodeSource apt repo key, so it stays transient — installed here and purged
# at the end of the layer.
RUN apt-get update \
 && apt-get install -y --no-install-recommends gnupg \
 && curl -fsSL "https://deb.nodesource.com/setup_${NODE_VERSION}.x" | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
 && npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" \
 && command -v claude >/dev/null \
 && claude --version \
 && npm cache clean --force \
 && apt-get purge -y gnupg \
 && apt-get autoremove -y \
 && rm -rf /var/lib/apt/lists/*

# Non-root agent user (uid/gid 1000) — parity with the other agent images so a
# bind-mounted workspace continues to work without a chown.
ARG AGENT_UID=1000
ARG AGENT_GID=1000
RUN groupadd --gid "${AGENT_GID}" agent \
 && useradd  --uid "${AGENT_UID}" --gid "${AGENT_GID}" --create-home --shell /bin/bash agent

WORKDIR /app

# Install the orchestrator's deps (langgraph + checkpointer + a2a-sdk + httpx)
# first so iterative source edits don't bust the dependency layer cache.
COPY agents/magazine-langgraph-orchestrator/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
 && rm /tmp/requirements.txt

# Install the Spring Voyage Agent SDK from source (not on PyPI yet) — the
# orchestrator imports it at module top-level for the A2A server + lifecycle
# hooks, so a missing SDK exits the process before uvicorn binds.
COPY agents/spring-voyage-agent-sdk /tmp/spring-voyage-agent-sdk
RUN pip install --no-cache-dir /tmp/spring-voyage-agent-sdk \
 && rm -rf /tmp/spring-voyage-agent-sdk

# Copy the orchestrator package last (iterates most often).
COPY agents/magazine-langgraph-orchestrator/orchestrator ./orchestrator
COPY agents/magazine-langgraph-orchestrator/pyproject.toml ./pyproject.toml

RUN chown -R agent:agent /app
USER agent

EXPOSE 8999

# The a2a-process launcher (A2AProcessLauncher.PrepareAsync) leaves
# AgentLaunchSpec.WorkingDirectory unset, so the dispatcher defaults the
# container's working directory to the per-agent workspace mount
# (/spring/members/<agentId>) — NOT /app. `python -m orchestrator` resolves the
# package from sys.path, and the orchestrator package lives at /app (it is run
# from source, not pip-installed), so pin /app on PYTHONPATH. Without this the
# module is import-invisible from the workspace CWD: the container exits
# immediately with "No module named orchestrator" (exit 1) and the readiness
# probe times out, so the dispatcher reports "did not become ready".
ENV PYTHONPATH=/app

# tini as PID 1 so SIGTERM from the dispatcher reaches the uvicorn server.
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python", "-m", "orchestrator"]
