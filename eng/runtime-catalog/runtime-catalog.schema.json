{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spring.voyage/schemas/runtime-catalog.schema.json",
  "title": "Spring Voyage runtime catalogue (ADR-0038)",
  "description": "Schema for eng/runtime-catalog/runtime-catalog.yaml. Pins closed enums (adapter, authMethods element values, llmApiContract.name, runtime-entry launcher ids) so typos fail in CI rather than at startup.",
  "type": "object",
  "additionalProperties": false,
  "required": ["modelProviders", "agentRuntimes"],
  "properties": {
    "modelProviders": {
      "type": "array",
      "items": { "$ref": "#/$defs/modelProvider" }
    },
    "agentRuntimes": {
      "type": "array",
      "items": { "$ref": "#/$defs/agentRuntime" }
    }
  },
  "$defs": {
    "modelProvider": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "apiBaseUrl",
        "modelsEndpoint",
        "adapter",
        "authMethods",
        "llmApiContract",
        "defaultModels"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "apiBaseUrl": { "type": "string", "format": "uri" },
        "modelsEndpoint": { "type": "string", "minLength": 1 },
        "adapter": {
          "type": "string",
          "enum": ["anthropic", "openai-compatible", "google"]
        },
        "authMethods": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "enum": ["oauth", "api-key"] }
        },
        "llmApiContract": { "$ref": "#/$defs/llmApiContract" },
        "defaultModels": {
          "type": "array",
          "minItems": 0,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "llmApiContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "enum": ["anthropic", "openai", "google"] },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "agentRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "defaultImage",
        "launcher",
        "threadBinding",
        "modelProviders"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "defaultImage": { "type": "string", "minLength": 1 },
        "launcher": {
          "type": "string",
          "enum": [
            "claude-code-cli",
            "codex-cli",
            "gemini-cli",
            "spring-voyage-agent",
            "a2a-process"
          ]
        },
        "threadBinding": { "$ref": "#/$defs/threadBinding" },
        "modelProviders": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/agentRuntimeProviderEdge" }
        }
      }
    },
    "threadBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "enum": ["cli-arg", "env-var", "none"] },
        "argName": { "type": "string", "minLength": 1 },
        "envVarName": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "kind": { "const": "cli-arg" } } },
          "then": { "required": ["argName"] }
        },
        {
          "if": { "properties": { "kind": { "const": "env-var" } } },
          "then": { "required": ["envVarName"] }
        }
      ]
    },
    "agentRuntimeProviderEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "authMethod": { "type": "string", "enum": ["oauth", "api-key"] },
        "credentialEnvVar": { "type": "string", "minLength": 1 }
      },
      "dependentRequired": {
        "authMethod": ["credentialEnvVar"],
        "credentialEnvVar": ["authMethod"]
      }
    }
  }
}
