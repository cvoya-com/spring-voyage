# Spring Voyage — deployment environment file
#
# Quick start: run ./setup.sh — it copies this file to spring.env and
# prompts for the secrets every deployment must supply.
#
# Manual setup: copy to spring.env, fill in the values marked REQUIRED, and
# leave everything else at its default.  DO NOT commit spring.env.
#
# deploy.sh pre-processes this file with envsubst before passing it to
# Podman, so ${VAR} references to keys defined earlier are expanded.
# Use ${NAME} (not bare $NAME) for inter-variable references.
# Quote values that contain # or literal whitespace.

# ---------------------------------------------------------------------------
# Image tags
# ---------------------------------------------------------------------------
SPRING_IMAGE_TAG=latest
SPRING_PLATFORM_IMAGE=localhost/spring-voyage:${SPRING_IMAGE_TAG}

# Optional. Set to a GitHub PAT with read:packages scope and your GitHub
# username to pull pre-built agent images from GHCR instead of building them
# locally. Only used during setup.sh.
# GHCR_PAT=ghp_...
# GHCR_USER=your-github-username

# Stock image overrides — defaults are baked into deploy.sh; uncomment to pin.
# POSTGRES_IMAGE=docker.io/library/postgres:17
# REDIS_IMAGE=docker.io/library/redis:7
# CADDY_IMAGE=docker.io/library/caddy:2
# DAPR_IMAGE=docker.io/daprio/dapr:1.17.4
# OLLAMA_IMAGE=docker.io/ollama/ollama:latest

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=spring
# REQUIRED — change before first start (setup.sh generates a random value)
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=spring

# ---------------------------------------------------------------------------
# Redis — leave REDIS_PASSWORD empty to disable auth (fine for local dev).
# ---------------------------------------------------------------------------
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Connection strings consumed by the .NET hosts and Dapr components.
# ---------------------------------------------------------------------------
ConnectionStrings__SpringDb=Host=spring-postgres;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD}

# Dapr state-store / pub-sub components read the Postgres DSN via
# secretstores.local.env; keep this in sync with the values above.
SPRING_POSTGRES_CONNECTION_STRING=host=spring-postgres port=5432 user=${POSTGRES_USER} password=${POSTGRES_PASSWORD} dbname=${POSTGRES_DB} sslmode=disable

# ---------------------------------------------------------------------------
# Dapr sidecar — path to delegated-agent Dapr components on the HOST.
#
# The dispatcher bind-mounts this directory (its profiles/<provider>/ subdir)
# into agent sidecars it launches via Podman.  Must be an absolute path that
# resolves on the machine running spring-voyage-host.sh.  For bundle installs
# setup.sh fills this in; for a source checkout `deploy.sh up` auto-resolves
# it to eng/dapr/components/delegated-spring-voyage-agent when it is left as
# the placeholder below or points at a path that does not exist (#3101).
# ---------------------------------------------------------------------------
Dapr__Sidecar__DelegatedSpringVoyageAgentComponentsPath=/absolute/path/to/spring-voyage/eng/dapr/components/delegated-spring-voyage-agent

# ---------------------------------------------------------------------------
# Worker MCP server port.  Agent containers reach the worker's MCP endpoint
# at host.docker.internal:${Mcp__Port}/mcp/.  Override if 5050 conflicts.
# ---------------------------------------------------------------------------
Mcp__Port=5050

# ---------------------------------------------------------------------------
# ASP.NET Core / .NET runtime
# ---------------------------------------------------------------------------
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://0.0.0.0:8080
DOTNET_NOLOGO=true
DOTNET_CLI_TELEMETRY_OPTOUT=true

# ---------------------------------------------------------------------------
# DataProtection key ring — must be bind-mounted so encrypted cookies and
# OAuth session tokens survive container rebuilds (#337).
# ---------------------------------------------------------------------------
DataProtection__KeysPath=/home/app/.aspnet/DataProtection-Keys

# ---------------------------------------------------------------------------
# Authentication mode.
#
# LocalDev=true installs a pass-through auth handler that authenticates every
# request as the default local user.  Correct for a single-operator local
# deployment.  Set to false for multi-user or hosted deployments and
# provision API tokens via /api/v1/auth/tokens.
# ---------------------------------------------------------------------------
LocalDev=true

# ---------------------------------------------------------------------------
# Secrets at-rest encryption — REQUIRED.
#
# Generate with:  openssl rand -base64 32
# setup.sh generates this automatically.  The same key must be used by
# spring-api and spring-worker; they both encrypt/decrypt against it.
# ---------------------------------------------------------------------------
SPRING_SECRETS_AES_KEY=REPLACE_ME_WITH_BASE64_32_BYTES

# ---------------------------------------------------------------------------
# Package catalog root (inside the container — do not change).
# ---------------------------------------------------------------------------
Packages__Root=/packages

# ---------------------------------------------------------------------------
# Public hostname + scheme — used by Caddy for TLS and for building redirect URIs.
#
# DEPLOY_HOSTNAME: single-host default (path-routed Caddyfile).
#   Set to your FQDN for automatic Let's Encrypt TLS.
#   Leave as "localhost" for local-only dev.
#
# DEPLOY_SCHEME: "http" or "https". Drives both the scheme Caddy serves
#   (the Caddyfile site is {$DEPLOY_SCHEME:http}://{$DEPLOY_HOSTNAME}) and the
#   scheme of the OAuth redirect / webhook URLs below. install.sh and setup.sh
#   derive it from the hostname: http for localhost/loopback (no public cert),
#   https for a real FQDN. Keep it http for localhost — Caddy cannot serve TLS
#   for localhost, so a https://localhost redirect is reset by the browser.
#   Override only for non-standard fronting (e.g. TLS terminated upstream).
#
# ACME_EMAIL: Let's Encrypt contact address for expiry/revocation notices.
#   Recommended for public FQDNs.
#
# TLS_MODE: how Caddy obtains the certificate when DEPLOY_SCHEME=https — HTTPS
#   does NOT require an internet-facing host (ADR-0068); install.sh sets it for you.
#     auto      (default) Let's Encrypt for a public FQDN; Caddy's internal CA
#               for https://localhost. Needs public DNS + open 80/443 for a cert.
#     internal  Caddy's local CA issues a cert for ANY hostname — no public DNS,
#               no open ports, works on high ports. Private/LAN HTTPS. Distribute
#               Caddy's root CA (in the spring-caddy-data volume) to clients.
#     custom    Serve your own cert from TLS_CERT_FILE + TLS_KEY_FILE (mount them
#               into spring-caddy; see the commented volume in docker-compose.yml).
#   TLS_CERT_FILE / TLS_KEY_FILE default to /etc/caddy/tls/tls.crt and tls.key.
#
# Per-service hostnames: set WEB_HOSTNAME / API_HOSTNAME / WEBHOOK_HOSTNAME
# and switch to Caddyfile.multi-host via SPRING_CADDYFILE.
# ---------------------------------------------------------------------------
DEPLOY_HOSTNAME=localhost
# DEPLOY_SCHEME=http
# ACME_EMAIL=ops@example.com
# TLS_MODE=auto
# TLS_CERT_FILE=/etc/caddy/tls/tls.crt
# TLS_KEY_FILE=/etc/caddy/tls/tls.key
# WEB_HOSTNAME=app.example.com
# API_HOSTNAME=api.example.com
# WEBHOOK_HOSTNAME=hooks.example.com
# SPRING_CADDYFILE=Caddyfile.multi-host

# ---------------------------------------------------------------------------
# Host-published HTTP/HTTPS ports for the Caddy reverse proxy.
#
# Caddy always listens on 80/443 *inside* the container; these only remap the
# host-side binding. Set them if another service on the host already owns
# 80/443 — install.sh sets them automatically when its pre-flight detects a
# conflict.
#
# Rootless caveat: rootless Podman cannot bind ports below the kernel's
# net.ipv4.ip_unprivileged_port_start (default 1024), so 80/443 fail even when
# free. Either lower that floor once
#   (echo 'net.ipv4.ip_unprivileged_port_start=80' | sudo tee /etc/sysctl.d/99-spring-voyage.conf && sudo sysctl --system)
# or set high ports here. install.sh walks you through this.
#
# Caveat: moving HTTP off 80 or HTTPS off 443 disables Caddy's automatic
# Let's Encrypt — ACME validates against the public host's 80/443. Front
# Caddy with a reverse proxy or terminate TLS upstream in that case.
# ---------------------------------------------------------------------------
# CADDY_HTTP_PORT=80
# CADDY_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Local AI (Ollama) — optional LLM backend, no API key required.
#
# OLLAMA_MODE=container  runs docker.io/ollama/ollama as spring-ollama on
#                        spring-net.  CPU-only by default.
# OLLAMA_MODE=host       platform talks to a host-installed Ollama.  Recommended
#                        on macOS (Metal GPU does not pass through into Podman
#                        containers). You can also select this per run with:
#                        ./deploy.sh up --local-ollama. Host mode generates
#                        a delegated-agent Dapr profile under
#                        ~/.spring-voyage/deployment so agent sidecars use
#                        the host endpoint too.
# OLLAMA_GPU=nvidia      enable GPU passthrough on Linux / WSL2.
# ---------------------------------------------------------------------------
# LanguageModel__Ollama__Enabled=true
# LanguageModel__Ollama__DefaultModel=llama3.2:3b
# LanguageModel__Ollama__BaseUrl=http://spring-ollama:11434
# LanguageModel__Ollama__RequireHealthyAtStartup=false
# OLLAMA_MODE=container
# OLLAMA_GPU=
# OLLAMA_DEFAULT_MODEL=llama3.2:3b
# OLLAMA_PORT=11434
#
# macOS host-mode URL (host.containers.internal resolves to the Podman host).
# deploy.sh --local-ollama injects this automatically after verifying
# http://127.0.0.1:11434/api/tags; set it here only when you want host mode
# to be permanent.
# LanguageModel__Ollama__BaseUrl=http://host.containers.internal:11434

# ---------------------------------------------------------------------------
# IAgentContext bootstrap — required for LLM-backed agent containers.
# Routes tenant→platform traffic through Caddy on spring-tenant-default
# (ADR-0028 Decision D).  Do not change for the standard OSS topology.
# ---------------------------------------------------------------------------
AgentContext__Bucket2Url=http://spring-caddy:8443/api/v1/
AgentContext__TelemetryUrl=http://spring-caddy:8443/

# ---------------------------------------------------------------------------
# spring-dispatcher — host-process service (#513, #1063).
#
# Runs as a long-lived host process managed by spring-voyage-host.sh (not in
# a container).  deploy.sh sources the auto-generated dispatcher.env before
# launching the worker, so SPRING_DISPATCHER_WORKER_TOKEN does not need to
# be set here for normal operation.
#
# Override only when running the worker outside deploy.sh or rotating the
# bearer token on a live deployment.
# ---------------------------------------------------------------------------
# Dispatcher__BaseUrl is injected per-service by deploy.sh / docker-compose
# (worker only) and must not be set here — it would leak into all containers
# via --env-file and trigger a spurious warning on the API host.
#
# CallbackBaseUrl__BaseUrl (#2586) is likewise injected per-service by
# deploy.sh / docker-compose. It is the agent-reachable base URL the worker's
# launcher stamps onto runtime containers as SPRING_CALLBACK_URL — the
# tenant-facing Caddy listener (http://spring-caddy:8443/) from which the
# OTLP-ingest endpoint is derived (ADR-0051).
# SPRING_DISPATCHER_WORKER_TOKEN=  # auto-generated on first spring-voyage-host.sh start
# SPRING_DEFAULT_TENANT_ID=default
# SPRING_DISPATCHER_HOST=0.0.0.0
# SPRING_DISPATCHER_PORT=8090
# SPRING_DISPATCHER_WORKSPACE_ROOT=~/.spring-voyage/workspaces
# SPRING_HOST_STATE_DIR=~/.spring-voyage/host

# ---------------------------------------------------------------------------
# GitHub App credentials — REQUIRED for GitHub connector features.
#
# AppId and AppSlug are fixed for the shared spring-voyage GitHub App.
# PrivateKeyPem and WebhookSecret are per-deployment secrets:
#   - PrivateKeyPem: generate a new key at
#       https://github.com/settings/apps/spring-voyage → "Private keys"
#   - WebhookSecret: generated by setup.sh; register it at
#       https://github.com/settings/apps/spring-voyage → Webhook
#
# Env-file quoting rules (#1186):
#   - PrivateKeyPem MUST be single-quoted (bash pass-through).
#   - AppId MUST be unquoted (numeric; .NET binder rejects "12345").
#   - Encode the PEM as a single line with literal \n between blocks.
#     setup.sh handles this conversion automatically.
# ---------------------------------------------------------------------------
# GitHub__AppId=
# GitHub__AppSlug=
# GitHub__PrivateKeyPem='-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----'
# GitHub__WebhookSecret=

# GitHub OAuth credentials — required for "Link GitHub account" in the portal.
# ClientId and ClientSecret come from your own GitHub App's "OAuth credentials"
# section.  RedirectUri must match a Callback URL registered on the App settings
# page; install.sh / setup.sh derive it from DEPLOY_HOSTNAME automatically. Its
# scheme MUST match DEPLOY_SCHEME above — http for a localhost/loopback install
# (the default), https for a public FQDN. A https://localhost value will not
# work: Caddy serves localhost over plain HTTP, so the browser redirect back
# from GitHub is reset (ERR_CONNECTION_RESET).
# GitHub__OAuth__ClientId=
# GitHub__OAuth__ClientSecret=
# GitHub__OAuth__RedirectUri=http://localhost/api/v1/tenant/connectors/github/oauth/callback

# Slack OAuth credentials — used by the Slack connector's runtime OAuth flow.
# Optional — leave unset if you run `spring connector slack install --write-tenant-secrets`
# (or `--write-secrets`), which persists the same four values into the platform's
# secret store. The runtime resolves credentials per call through the chain
# tenant-secret → platform-secret → env-config (issue #2849); a tenant-scoped row
# transparently overrides an env value.
# Generate the four values with `spring connector slack install` — see
# docs/guide/operator/slack-app-setup.md.
# Slack__OAuth__ClientId=
# Slack__OAuth__ClientSecret=
# Slack__OAuth__SigningSecret=
# Slack__OAuth__RedirectUri=https://localhost/api/v1/tenant/connectors/slack/oauth/callback

# ---------------------------------------------------------------------------
# LLM provider credentials are TIER-2 configuration: per-tenant defaults
# that units inherit.  Set them after the first deploy via the CLI:
#
#   spring secret create --scope tenant anthropic-api-key --value "sk-ant-..."
#   spring secret create --scope tenant openai-api-key    --value "sk-..."
#
# Or via the portal: Settings → Tenant defaults.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Webhook relay (consumed by relay.sh — local-dev SSH reverse tunnel).
# Not passed into containers.
# ---------------------------------------------------------------------------
# RELAY_HOST=relay.example.com
# RELAY_USER=webhooks
# RELAY_SSH_PORT=22
# RELAY_REMOTE_PORT=19080
# RELAY_LOCAL_PORT=8080
# RELAY_SSH_KEY=~/.ssh/relay_ed25519
