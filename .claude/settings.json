{
  "permissions": {
    "allow": [
      "Skill(adr-new)",
      "Skill(areas)",
      "Skill(build)",
      "Skill(format)",
      "Skill(lint)",
      "Skill(openapi-diff)",
      "Skill(release-notes)",
      "Skill(spring-voyage-daily-triage)",
      "Skill(test)",
      "Skill(triage)",
      "Skill(web)"
    ]
  },
  "enabledPlugins": {
    "csharp-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/eng/agent-hooks/guard-generated-files.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'which notify-send >/dev/null 2>&1 && notify-send \"Agent task\" \"Task completed\" || which osascript >/dev/null 2>&1 && osascript -e \"display notification \\\"Task completed\\\" with title \\\"Agent task\\\"\" || true'"
          }
        ]
      }
    ]
  }
}
