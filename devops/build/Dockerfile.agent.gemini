# syntax=docker/dockerfile:1.7
#
# Spring Voyage — Gemini CLI agent image (#2108).
#
# Mirrors `Dockerfile.agent.claude-code` with the Gemini CLI substituted
# for Claude Code. Conformance path is identical: BYOI path 1 from
# `docs/architecture/agent-runtime.md` § 7 — `FROM` the agent-base image
# (which already bundles the A2A bridge sidecar on :8999) and
# `RUN`-install the tool we want the bridge to spawn.
#
# Wire contract recap (full text in agent-runtime.md § 7; see also
# `devops/build/Dockerfile.agent.claude-code` for an annotated copy):
#
#   * The base image's ENTRYPOINT runs the TypeScript A2A bridge on
#     `${AGENT_PORT:-8999}`. We do NOT override it.
#   * The dispatcher (GeminiLauncher.PrepareAsync) stamps SPRING_AGENT_ARGV
#     into the container env at launch time as a JSON array — for Gemini:
#
#         SPRING_AGENT_ARGV='["gemini","--prompt","","--output-format","stream-json","--yolo","--skip-trust"]'
#
#     The bridge then appends [--session-id|--resume, <thread.id>] (per
#     SPRING_THREAD_ID_ARG_CREATE / _RESUME) and pipes the user's prompt
#     to stdin. The CLI's `--prompt` flag is set to the empty string —
#     that is the documented trigger for headless mode (`gemini --help`:
#     "Run in non-interactive (headless) mode with the given prompt.
#     Appended to input on stdin (if any).") and it is the empty body
#     plus stdin payload that becomes the actual user message.
#   * Google AI Studio credentials are NOT baked into this image. The
#     launcher injects them as `GOOGLE_API_KEY` at dispatch time and the
#     bridge forwards them unchanged. `GEMINI_CLI_HOME` is set to
#     `/workspace` so chat checkpoints live on the per-agent workspace
#     volume and survive container restart (ADR-0041 / #2103).
#
# Build:
#   devops/build/build-agent-images.sh
#       (preferred — builds agent-base, claude-code-base, gemini-base,
#        and spring-voyage-agent together)
#
#   docker build \
#     -f devops/build/Dockerfile.agent.gemini \
#     -t localhost/spring-voyage-agent-gemini:latest \
#     --build-arg AGENT_BASE_IMAGE=ghcr.io/cvoya-com/spring-voyage-agent-base:dev \
#     .
#
# `AGENT_BASE_IMAGE` defaults to the agent-base tag shipped alongside this
# release. Override it to point at a locally-built agent-base when the
# published image isn't yet in your pull cache.

ARG AGENT_BASE_IMAGE=ghcr.io/cvoya-com/spring-voyage-agent-base:dev

FROM ${AGENT_BASE_IMAGE}

# Pin the Gemini CLI explicitly so `docker build` is reproducible across
# hosts. Override at build time with --build-arg GEMINI_CLI_VERSION=<x.y.z>
# to roll forward without editing this file. The version below was the
# latest stable on npm at PR-author time (verified via `npm view
# @google/gemini-cli version`).
ARG GEMINI_CLI_VERSION=0.41.2

# Google distributes the CLI as @google/gemini-cli on the public npm
# registry; the package's binary is `gemini`. The probe (`gemini
# --version`) makes any install regression fail the build loudly instead
# of producing a silently broken image.
#
# We need root to write to npm's global prefix; the base image runs as
# `agent`, so we drop down for the install and switch back so we keep
# the non-root posture the dispatcher and the bridge sidecar expect.
USER root
RUN export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 \
 && npm install -g "@google/gemini-cli@${GEMINI_CLI_VERSION}" \
 && command -v gemini >/dev/null \
 && gemini --version
USER agent

# No CMD / ENTRYPOINT override — inherit the base image's bridge entrypoint
# unchanged. The dispatcher's GeminiLauncher supplies SPRING_AGENT_ARGV.
