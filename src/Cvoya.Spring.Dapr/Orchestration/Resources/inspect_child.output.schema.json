{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "inspect_child.output",
  "description": "Output of inspect_child — single child descriptor.",
  "type": "object",
  "properties": {
    "address": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "kind": {
      "type": "string",
      "enum": ["agent", "unit"]
    },
    "description": {
      "type": ["string", "null"]
    },
    "expertise": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "description": "Current lifecycle / readiness status (runtime-defined; see query_child_status for the canonical state-only shape)."
    }
  },
  "required": ["address", "displayName", "kind"],
  "additionalProperties": true
}
